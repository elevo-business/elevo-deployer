# ═══════════════════════════════════════════
# ELEVO Deployer — Environment Variables
# ═══════════════════════════════════════════

# ─── PFLICHT ───

# GitHub Personal Access Token (Classic)
# Erstellen: github.com → Settings → Developer Settings → Personal Access Tokens → Tokens (classic)
# Scope: "repo" (Full control of private repositories)
# WICHTIG: Token muss Zugriff auf die Org "elevo-business" haben
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Organisation
GITHUB_ORG=elevo-business

# ─── OPTIONAL: Auth ───

# Einfacher API-Key für Zugangsschutz (oder Cloudflare Zero Trust nutzen)
DEPLOYER_API_KEY=

# ─── OPTIONAL: Coolify Integration ───

# Coolify API Token (Settings → Security → API Tokens)
COOLIFY_TOKEN=

# Coolify Dashboard URL
COOLIFY_URL=https://159.195.37.216:8000

# Coolify Server UUID (in Coolify unter Servers → dein Server → UUID in der URL)
COOLIFY_SERVER_ID=

# Coolify Project UUID (unter Projects → dein Projekt → UUID in der URL)
COOLIFY_PROJECT_ID=

# ─── OPTIONAL: Sonstiges ───

# Preview-Domain (Standard: preview.elevo.solutions)
PREVIEW_DOMAIN=preview.elevo.solutions

# Port (Standard: 3000)
PORT=3000

# Coolify GitHub App Source ID (für automatische App-Erstellung)
GITHUB_APP_ID=
