# ═══════════════════════════════════════════
# ELEVO Deployer v4.1 — Environment Variables
# ═══════════════════════════════════════════

# ─── PFLICHT ───

# GitHub Personal Access Token (Classic)
# Erstellen: github.com → Settings → Developer Settings → Personal Access Tokens → Tokens (classic)
# Scope: "repo" (Full control of private repositories)
# WICHTIG: Token muss Zugriff auf die Org "elevo-business" haben
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Organisation
GITHUB_ORG=elevo-business

# ─── AUTH ───

# Web UI Secret — schützt das Dashboard (Browser-Login + Cookie)
DEPLOY_SECRET=

# Programmatische API-Keys (kommagetrennt) — für CI, Agenten, Automatisierungen
# Jeder Key funktioniert als: Authorization: Bearer <KEY>
# Beispiel: API_KEYS=key1,key2,key3
API_KEYS=

# ─── OPTIONAL: Coolify Integration ───

# Coolify API Token (Settings → Security → API Tokens)
COOLIFY_TOKEN=

# Coolify Dashboard URL
COOLIFY_URL=https://159.195.37.216:8000

# Coolify Server UUID (in Coolify unter Servers → dein Server → UUID in der URL)
COOLIFY_SERVER_UUID=

# Coolify Project UUID (unter Projects → dein Projekt → UUID in der URL)
COOLIFY_PROJECT_UUID=

# Coolify Destination UUID
COOLIFY_DEST_UUID=

# ─── OPTIONAL: KI & Outreach ───

# Anthropic API Key (für Preview-Generierung mit Claude)
ANTHROPIC_API_KEY=

# Pipedrive API Key (für CRM-Sync und Mail-Versand)
PIPEDRIVE_API_KEY=

# Pipedrive Custom Field Key für Outreach-Status
PIPEDRIVE_OUTREACH_FIELD=

# Pipedrive Custom Field Value beim Mail-Senden
PIPEDRIVE_OUTREACH_VALUE=

# Google Places API Key (für Business-Recherche)
GOOGLE_PLACES_KEY=

# ─── OPTIONAL: Sonstiges ───

# Port (Standard: 3000)
PORT=3000

# Coolify GitHub App UUID (für automatische App-Erstellung)
GITHUB_APP_UUID=
